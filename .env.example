# Database
DB_HOST=localhost
DB_NAME=mksab_db
DB_USER=root
DB_PASSWORD=

# Server
PORT=3000
NODE_ENV=development

# JWT
JWT_ACCESS_SECRET=change_me_access_secret
JWT_REFRESH_SECRET=change_me_refresh_secret
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# Email — Brevo SMTP Relay
# Get credentials from: app.brevo.com → SMTP & API → SMTP tab
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Mksab
MAIL_FROM_EMAIL=noreply@mksab.com
APP_FRONTEND_URL=http://localhost:5173

# Bright Data
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_DATASET_ENDPOINT=https://api.brightdata.com/datasets/v3

# Lead Search Datasets
# Put the dataset IDs that should power the new dataset-based Website/LinkedIn search path.
BRIGHT_DATA_WEBSITE_DATASET_ID=
BRIGHT_DATA_LINKEDIN_DATASET_ID=

# Optional dataset source labels shown internally in normalized records/warnings.
BRIGHT_DATA_WEBSITE_SOURCE_DATASET=
BRIGHT_DATA_LINKEDIN_SOURCE_DATASET=

# Optional JSON templates when a dataset needs a custom input shape.
# Example:
# BRIGHT_DATA_WEBSITE_DATASET_INPUT_TEMPLATE={"keyword":"{{keyword}}","city":"{{city}}","country":"{{country}}","page":{{page}},"limit":{{limit}}}
# BRIGHT_DATA_LINKEDIN_DATASET_INPUT_TEMPLATE={"keyword":"{{keyword}}","location":"{{location}}","page":{{page}},"limit":{{limit}}}
BRIGHT_DATA_WEBSITE_DATASET_INPUT_TEMPLATE=
BRIGHT_DATA_LINKEDIN_DATASET_INPUT_TEMPLATE=

# Optional JSON object for extra query params appended to /datasets/v3/scrape.
# Example: {"type":"discover_new","discover_by":"keyword"}
BRIGHT_DATA_WEBSITE_DATASET_QUERY_PARAMS=
BRIGHT_DATA_LINKEDIN_DATASET_QUERY_PARAMS=

# Analysis Module - Gemini
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANALYSIS_GEMINI_API_KEY=
ANALYSIS_AI_MODEL=gemini-2.5-flash
ANALYSIS_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
ANALYSIS_AI_TIMEOUT_MS=30000
ANALYSIS_AI_TEMPERATURE=0.2
ANALYSIS_AI_MAX_RETRIES=2
ANALYSIS_AI_RETRY_BASE_DELAY_MS=1000
ANALYSIS_AI_RETRY_MAX_DELAY_MS=8000
# Optional fallback model chain (comma-separated), used when primary model is overloaded.
ANALYSIS_AI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest

# Analysis Module - Google PageSpeed Insights
PAGESPEED_API_KEY=
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_API_KEY=
ANALYSIS_PAGESPEED_TIMEOUT_MS=20000
ANALYSIS_PAGESPEED_INCLUDE_DESKTOP=false

# Analysis Module - Scraping (Bright Data)
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_WS_ENDPOINT=
BRIGHTDATA_WS_ENDPOINT=
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_UNLOCKER_ZONE=
BRIGHTDATA_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
ANALYSIS_SCRAPING_TIMEOUT_MS=15000
ANALYSIS_UNLOCKER_MAX_POLL_RETRIES=8
ANALYSIS_UNLOCKER_POLL_INTERVAL_MS=1500

# Supabase Storage (Analysis + Reports)
SUPABASE_URL=
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_STORAGE_BUCKET=
ANALYSIS_SCREENSHOT_SUPABASE_BUCKET=
SUPABASE_STORAGE_BUCKET_ANALYSIS_SCREENSHOTS=

# Reports Module Storage
REPORTS_SUPABASE_BUCKET=
REPORTS_STORAGE_TIMEOUT_MS=20000
REPORTS_STORAGE_USE_SIGNED_URL=false
REPORTS_STORAGE_SIGNED_URL_EXPIRES_IN_SEC=86400
