# =========================
# Core App
# =========================
NODE_ENV=production
PORT=3000

# =========================
# Database
# =========================
DATABASE_URL=
DB_HOST=127.0.0.1
DB_PORT=3306
DB_NAME=mksab_db
DB_USER=root
DB_PASSWORD=
DB_SSL_MODE=
DB_SSL_REJECT_UNAUTHORIZED=false

# =========================
# Auth
# =========================
JWT_ACCESS_SECRET=replace_with_a_long_random_secret

# Legacy / currently unused by code, kept for compatibility if needed later
JWT_REFRESH_SECRET=
JWT_ACCESS_EXPIRES_IN=15m
JWT_REFRESH_EXPIRES_IN=7d

# =========================
# Frontend URLs
# =========================
APP_FRONTEND_URL=https://your-frontend-domain.com
APP_FRONTEND_INVITE_ACCEPT_PATH=/accept-invite
APP_FRONTEND_RESET_PASSWORD_PATH=/reset-password

# =========================
# Email (Brevo SMTP)
# =========================
SMTP_HOST=smtp-relay.brevo.com
SMTP_PORT=587
SMTP_USER=
SMTP_PASS=
SMTP_FROM_NAME=Mksab
MAIL_FROM_EMAIL=noreply@your-domain.com

# =========================
# Brevo Marketing Campaigns
# =========================
BREVO_MARKETING_ENABLED=true
BREVO_MARKETING_API_KEY=
BREVO_MARKETING_BASE_URL=https://api.brevo.com/v3
BREVO_MARKETING_TIMEOUT_MS=30000
BREVO_MARKETING_DEFAULT_SENDER_EMAIL=
BREVO_MARKETING_DEFAULT_SENDER_NAME=Maksab
BREVO_MARKETING_FOLDER_ID=
BREVO_MARKETING_FOLDER_NAME=Maksab Campaigns

# =========================
# Client Email Campaigns
# =========================
CLIENT_EMAIL_CAMPAIGN_MAX_RECIPIENTS=200
CLIENT_EMAIL_CAMPAIGN_ALLOW_WARNING_OVERRIDE=true
CLIENT_EMAIL_CAMPAIGN_EMPLOYEE_CAN_OVERRIDE_RISKY=false
CLIENT_EMAIL_CAMPAIGN_MANAGER_CAN_OVERRIDE_SUPPRESSION=true
CLIENT_EMAIL_CAMPAIGN_COMPLAINED_IS_BLOCKED=true
CLIENT_EMAIL_CAMPAIGN_UNSUBSCRIBED_IS_BLOCKED=true

# =========================
# Gemini / AI Analysis
# =========================
GEMINI_API_KEY=
GEMINI_MODEL=gemini-2.5-flash
ANALYSIS_GEMINI_API_KEY=
ANALYSIS_GEMINI_ENDPOINT=https://generativelanguage.googleapis.com/v1beta/models
ANALYSIS_AI_MODEL=gemini-2.5-flash
ANALYSIS_AI_TIMEOUT_MS=30000
ANALYSIS_AI_TEMPERATURE=0.2
ANALYSIS_AI_MAX_RETRIES=2
ANALYSIS_AI_RETRY_BASE_DELAY_MS=1000
ANALYSIS_AI_RETRY_MAX_DELAY_MS=8000
ANALYSIS_AI_FALLBACK_MODELS=gemini-2.0-flash,gemini-flash-latest
ANALYSIS_OUTPUT_LANGUAGE=ar

# Optional environment fallback for the analysis system prompt.
# The preferred source is now the system-settings table.
ANALYSIS_GEMINI_SYSTEM_PROMPT=

# Optional legacy aliases
ANALYSIS_AI_API_KEY=
ANALYSIS_AI_ENDPOINT=
ANALYSIS_AI_SYSTEM_PROMPT=
GEMINI_API_BASE_URL=

# =========================
# Google PageSpeed
# =========================
PAGESPEED_API_KEY=
ANALYSIS_PAGESPEED_TIMEOUT_MS=20000
ANALYSIS_PAGESPEED_INCLUDE_DESKTOP=false

# Optional aliases
GOOGLE_PAGESPEED_API_KEY=
GOOGLE_API_KEY=
PAGESPEED_API_ENDPOINT=

# =========================
# Bright Data - Shared
# =========================
BRIGHT_DATA_API_TOKEN=
BRIGHT_DATA_WS_ENDPOINT=

# Optional aliases accepted by the code
BRIGHTDATA_API_TOKEN=
BRIGHTDATA_API_KEY=
BRIGHTDATA_WS_ENDPOINT=

# =========================
# Bright Data - Lead Search SERP
# =========================
BRIGHT_DATA_SERP_ZONE=
BRIGHT_DATA_SERP_ENDPOINT=https://api.brightdata.com/serp
LEAD_SEARCH_HTTP_TIMEOUT_MS=15000
LEAD_SEARCH_SERP_MAX_POLL_RETRIES=8
LEAD_SEARCH_SERP_POLL_INTERVAL_MS=1500
LEAD_SEARCH_SERP_TIKTOK_MAX_POLL_RETRIES=12
LEAD_SEARCH_SERP_TIKTOK_POLL_INTERVAL_MS=2000

# Optional aliases
BRIGHTDATA_SERP_ZONE=
BRIGHTDATA_SERP_ENDPOINT=

# =========================
# Bright Data - Dataset Search
# =========================
BRIGHT_DATA_DATASET_ENDPOINT=https://api.brightdata.com/datasets/v3
BRIGHT_DATA_WEBSITE_DATASET_ID=
BRIGHT_DATA_LINKEDIN_DATASET_ID=
BRIGHT_DATA_WEBSITE_SOURCE_DATASET=
BRIGHT_DATA_LINKEDIN_SOURCE_DATASET=
BRIGHT_DATA_WEBSITE_DATASET_INPUT_TEMPLATE=
BRIGHT_DATA_LINKEDIN_DATASET_INPUT_TEMPLATE=
BRIGHT_DATA_WEBSITE_DATASET_QUERY_PARAMS=
BRIGHT_DATA_LINKEDIN_DATASET_QUERY_PARAMS=

# =========================
# Bright Data - Unlocker / Scraping
# =========================
BRIGHT_DATA_WEB_UNLOCKER_ZONE=
BRIGHT_DATA_UNLOCKER_ZONE=
BRIGHT_DATA_UNLOCKER_ENDPOINT=https://api.brightdata.com/request
ANALYSIS_SCRAPING_TIMEOUT_MS=15000
ANALYSIS_DIRECT_FETCH_TIMEOUT_MS=6000
ANALYSIS_UNLOCKER_MAX_POLL_RETRIES=8
ANALYSIS_UNLOCKER_POLL_INTERVAL_MS=1500

# Optional aliases
BRIGHTDATA_WEB_UNLOCKER_ZONE=
BRIGHTDATA_UNLOCKER_ZONE=
BRIGHTDATA_UNLOCKER_ENDPOINT=

# =========================
# Analysis Screenshots - Local Storage
# =========================
ANALYSIS_SCREENSHOT_LOCAL_STORAGE_DIR=storage/analysis-screenshots
ANALYSIS_SCREENSHOT_FILES_BASE_URL=/api/v1/analysis-screenshots
ANALYSIS_SCREENSHOT_TIMEOUT_MS=25000
ANALYSIS_SCREENSHOT_VIEWPORT_WIDTH=1440
ANALYSIS_SCREENSHOT_VIEWPORT_HEIGHT=900
ANALYSIS_SCREENSHOT_BIO_HEIGHT=900

# Legacy Supabase screenshot storage variables (not required in the current setup)
SUPABASE_URL=
SUPABASE_SERVICE_ROLE_KEY=
SUPABASE_ANON_KEY=
ANALYSIS_SCREENSHOT_SUPABASE_BUCKET=
SUPABASE_STORAGE_BUCKET_ANALYSIS_SCREENSHOTS=
ANALYSIS_SCREENSHOT_STORAGE_TIMEOUT_MS=20000
ANALYSIS_SCREENSHOT_USE_SIGNED_URL=false
ANALYSIS_SCREENSHOT_SIGNED_URL_EXPIRES_IN_SEC=86400

# =========================
# Reports - Local Storage
# =========================
REPORTS_LOCAL_STORAGE_DIR=storage/reports
REPORTS_FILES_BASE_URL=/api/v1/reports-files
REPORTS_TEMPLATE_VARIANT=legacy-full

# =========================
# Reports - PDF Rendering
# =========================
REPORTS_PDF_TIMEOUT_MS=90000
REPORTS_PDF_SET_CONTENT_WAIT_UNTIL=commit
# Keep empty to force local Chromium rendering only.
REPORTS_PDF_WS_ENDPOINT=
REPORTS_PDF_LOCAL_CHROME_PATH=
REPORTS_PDF_VIEWPORT_WIDTH=1240
REPORTS_PDF_VIEWPORT_HEIGHT=1754
REPORTS_PDF_PAGE_FORMAT=A4
REPORTS_PDF_ASSET_WAIT_TIMEOUT_MS=15000
REPORTS_PDF_SETTLE_DELAY_MS=350
REPORTS_PDF_STRIP_WEB_FONTS=true
PLAYWRIGHT_BROWSERS_PATH=0
REPORTS_PDF_SCREENSHOT_MAX_BYTES=4000000
REPORTS_PDF_SCREENSHOT_FETCH_TIMEOUT_MS=12000
REPORTS_SCREENSHOT_INTERNAL_ORIGIN=
# Example on Linux: /usr/share/fonts/truetype/noto/NotoNaskhArabic-Regular.ttf
REPORTS_PDF_ARABIC_FONT_PATH=

# Optional aliases / legacy report storage settings
REPORTS_BRIGHT_DATA_WS_ENDPOINT=
REPORTS_STORAGE_TIMEOUT_MS=20000
REPORTS_STORAGE_USE_SIGNED_URL=false
REPORTS_STORAGE_SIGNED_URL_EXPIRES_IN_SEC=86400

# Legacy report bucket settings (not required in the current local-storage setup)
SUPABASE_PUBLISHABLE_KEY=
SUPABASE_STORAGE_BUCKET=
REPORTS_SUPABASE_BUCKET=

# =========================
# Reports - WhatChimp Archiving
# =========================
WHATCHIMP_ENABLED=true
WHATCHIMP_TIMEOUT_MS=15000
WHATCHIMP_BASE_URL=https://app.whatchimp.com/api/v1
WHATCHIMP_API_TOKEN=

# Legacy alias accepted by the code
WHATCHIMP_API_KEY=

WHATCHIMP_LIST_ID=1
WHATCHIMP_REPORT_URL_FIELD_KEY=pdf_report_url
WHATCHIMP_PHONE_NUMBER_ID=

# Optional explicit endpoint overrides
WHATCHIMP_SUBSCRIBER_CREATE_URL=
WHATCHIMP_ASSIGN_CUSTOM_FIELDS_URL=

# Optional legacy alias for subscriber create endpoint
WHATCHIMP_WEBHOOK_URL=
